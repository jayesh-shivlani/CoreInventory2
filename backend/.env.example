PORT=4000
JWT_SECRET=change-me-in-production
DB_PATH=./data/coreinventory.db
# Comma-separated allowed browser origins. Leave empty to allow all origins.
ALLOWED_ORIGINS=http://localhost:5173
# Optional path to built frontend assets for serving from backend.
FRONTEND_DIST_PATH=../frontend/dist

# SMTP configuration for OTP email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
