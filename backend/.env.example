PORT=4000
JWT_SECRET=change-me-in-production

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated allowed browser origins. Leave empty to allow all origins.
ALLOWED_ORIGINS=http://localhost:5173

# Optional: serve built frontend assets from backend
FRONTEND_DIST_PATH=../frontend/dist

# Resend API key for OTP email delivery (optional – OTP logged to console if omitted)
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev

# SMTP (optional fallback/primary when set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Signup/OTP behavior
EXPOSE_DEV_OTP=true
STRICT_EMAIL_DOMAIN_CHECK=false
