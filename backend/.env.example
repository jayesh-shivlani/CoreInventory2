PORT=4000
JWT_SECRET=change-me-in-production

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Default admin seed credentials (change before deploying to production)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Admin User

# Comma-separated allowed browser origins. Leave empty to allow all origins.
ALLOWED_ORIGINS=http://localhost:5173

# Optional: serve built frontend assets from backend
FRONTEND_DIST_PATH=../frontend/dist

# Gmail SMTP for OTP email delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
FROM_EMAIL=your-email@gmail.com
SMTP_TIMEOUT_MS=15000
SMTP_MAX_ATTEMPTS=2

# Signup/OTP behavior
EXPOSE_DEV_OTP=true
STRICT_EMAIL_DOMAIN_CHECK=false
SIGNUP_OTP_TTL_MINUTES=10
RESET_OTP_TTL_MINUTES=10
