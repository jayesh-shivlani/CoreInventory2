PORT=4000
JWT_SECRET=change-me-in-production

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Default admin seed credentials (change before deploying to production)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Admin User

# Comma-separated allowed browser origins. In production this should be explicitly set.
ALLOWED_ORIGINS=http://localhost:5173

# Optional: serve built frontend assets from backend
FRONTEND_DIST_PATH=../frontend/dist

# Brevo email delivery
BREVO_API_KEY=your-brevo-api-key
FROM_EMAIL=your-verified-sender@example.com
EMAIL_TIMEOUT_MS=15000

# Signup/OTP behavior
EXPOSE_DEV_OTP=false
STRICT_EMAIL_DOMAIN_CHECK=false
SIGNUP_OTP_TTL_MINUTES=10
RESET_OTP_TTL_MINUTES=10